# Public HTTPS address assigned by your hosting platform.
PRODUCTDB_PUBLIC_URL=https://catalog.example.com

# Read product data directly from the LIVE Google Sheet.
PRODUCTDB_DATA_SOURCE=drive
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Persistent storage paths inside the mounted volume.
PRODUCTDB_USERS_PATH=/app/runtime/auth_users.json
PRODUCTDB_QUOTATIONS_PATH=/app/runtime/quotations
PRODUCTDB_LEADS_PATH=/app/runtime/leads.xlsx

# Used only on the first startup when auth_users.json does not exist.
PRODUCTDB_ADMIN_USERNAME=admin
PRODUCTDB_ADMIN_NAME=Quản trị viên
PRODUCTDB_ADMIN_PASSWORD=replace-with-a-long-random-password

# Hosting platforms normally provide PORT automatically.
PORT=8501
